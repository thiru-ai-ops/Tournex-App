<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF5E6">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/holo_orange_dark"
        android:padding="20dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Find Places by Mood"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSelectedMood"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Showing: Adventure Places"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:layout_marginTop="5dp" />
    </LinearLayout>

    <!-- Mood Buttons with Images -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="5"
                android:padding="10dp"
                android:background="@android:color/white">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_margin="4dp">

                    <ImageButton
                        android:id="@+id/btnAdventure"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@drawable/ic_adventure"
                        android:background="@drawable/mood_button_bg"
                        android:scaleType="centerCrop"
                        android:padding="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Adventure"
                        android:textSize="11sp"
                        android:textColor="#FF6B6B"
                        android:layout_marginTop="5dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_margin="4dp">

                    <ImageButton
                        android:id="@+id/btnRelax"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@drawable/ic_relax"
                        android:background="@drawable/mood_button_bg"
                        android:scaleType="centerCrop"
                        android:padding="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Relax"
                        android:textSize="11sp"
                        android:textColor="#4ECDC4"
                        android:layout_marginTop="5dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_margin="4dp">

                    <ImageButton
                        android:id="@+id/btnSpiritual"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@drawable/ic_spiritual"
                        android:background="@drawable/mood_button_bg"
                        android:scaleType="centerCrop"
                        android:padding="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Spiritual"
                        android:textSize="11sp"
                        android:textColor="#9B59B6"
                        android:layout_marginTop="5dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_margin="4dp">

                    <ImageButton
                        android:id="@+id/btnHeritage"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@drawable/ic_heritage"
                        android:background="@drawable/mood_button_bg"
                        android:scaleType="centerCrop"
                        android:padding="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Heritage"
                        android:textSize="11sp"
                        android:textColor="#F39C12"
                        android:layout_marginTop="5dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_margin="4dp">

                    <ImageButton
                        android:id="@+id/btnNature"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@drawable/ic_nature"
                        android:background="@drawable/mood_button_bg"
                        android:scaleType="centerCrop"
                        android:padding="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nature"
                        android:textSize="11sp"
                        android:textColor="#27AE60"
                        android:layout_marginTop="5dp" />
                </LinearLayout>

            </LinearLayout>

            <!-- Places Title -->
            <TextView
                android:id="@+id/tvPlaceTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Adventure Spots in Tamil Nadu"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/holo_orange_dark"
                android:padding="16dp" />

            <!-- Places Grid - Use androidx.gridlayout.widget.GridLayout -->
            <androidx.gridlayout.widget.GridLayout
                android:id="@+id/gridPlaces"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:padding="8dp">
            </androidx.gridlayout.widget.GridLayout>

        </LinearLayout>
    </ScrollView>
    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:menu="@menu/bottom_nav_menu_new"
        app:itemIconTint="@color/bottom_nav_color"
        app:itemTextColor="@color/bottom_nav_color"
        android:background="@android:color/white"
        app:elevation="8dp" />

</LinearLayout>